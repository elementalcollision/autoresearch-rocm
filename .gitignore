# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
worktrees/
queue/

# Agent prompt files (generated per-session by launchers)
CLAUDE.md
AGENTS.md

# Experimental code/artifacts
dev/

# Results — NEVER track experiment data in git.
# Each deployment produces its own results; tracking them causes
# cross-contamination when code is cloned to a new GPU instance.
/results.tsv
results/**/results.tsv
results/**/manifest.json
!results/**/.gitkeep

# Heartbeat status file (written by resilience system for external monitors)
.runner_status.json

# Suite PID lock file
.suite.pid
